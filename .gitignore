# This .gitignore should be placed at the root of your Unity project repository
#
# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset Store Tools
/[Aa]ssets/AssetStoreTools*

# IDE and editor files
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.VC.VC.opendb

# Unity generated meta files for ignored folders
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
crashlytics-build.properties

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app
*.exe

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary and backup files
*~
*.tmp
*.bak
*.swp
*.blend1
__pycache__/
*.pyc

# Rider
.idea/
*.sln.iml

# Visual Studio cache
.vsconfig

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Test results and coverage
/[Tt]est[Rr]esults/
/[Cc]ode[Cc]overage/
/Assets/InitTestScene*.unity
/Assets/InitTestScene*.unity.meta

# Local MCP or agent state
.mcp-local/
.codex-local/
